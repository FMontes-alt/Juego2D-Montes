# ===============================================
# Unity .gitignore
# ===============================================

# Carpetas generadas por Unity
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]serSettings/

# MemoryCaptures
/[Mm]emoryCaptures/

# Recordings
/[Rr]ecordings/

# Asset meta data should only be ignored when the corresponding asset is also ignored
!/[Aa]ssets/**/*.meta

# Autogenerated Crash Reports
sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage
*.app

# ===============================================
# Archivos de Visual Studio / Rider / IDEs
# ===============================================
.vs/
.vscode/
*.csproj
*.unityproj
*.sln
*.slnx
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# ===============================================
# Herramientas del Editor (Tools)
# ===============================================
/[Aa]ssets/[Ss]cripts/[Ee]ditor/

# ===============================================
# OS generated files
# ===============================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ===============================================
# Misc
# ===============================================
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Gradle (Android)
/[Aa]ssets/Plugins/Android/mainTemplate.gradle.meta

# TextMeshPro
/[Aa]ssets/TextMesh Pro/

# Addressables
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*
/[Aa]ssets/[Ss]treamingAssets/aa.meta
/[Aa]ssets/[Ss]treamingAssets/aa/*
